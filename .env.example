# Copy to .env and fill secrets. Never commit .env.

# --- Listen (cloud-safe default: loopback only) ---
MCP_SEARCH_BIND=127.0.0.1
MCP_SEARCH_PORT=8812

# --- Servers enabled on the gateway (comma-separated catalog names) ---
# Core (no paid keys):
# MCP_SEARCH_SERVERS=searxng-mcp-local
# Full:
MCP_SEARCH_SERVERS=searxng-mcp-local,tavily,firecrawl,brave,context7-docs,deepwiki,arxiv-mcp-server,npm-fetch-mcp-local

# --- Images ---
SEARXNG_MCP_IMAGE=xbeta/mcp-search:latest
SEARXNG_SECRET=change-me-to-a-long-random-string

# --- Optional paid / remote backends ---
TAVILY_API_KEY=
tavily.api_key=

FIRECRAWL_API_KEY=
firecrawl.api_key=

# Brave Search (Search plan key). Answers is a separate Brave product/key.
BRAVE_API_KEY=REPLACE_ME_BRAVE_SEARCH_API_KEY
brave.api_key=REPLACE_ME_BRAVE_SEARCH_API_KEY
BRAVE_ANSWERS_API_KEY=REPLACE_ME_BRAVE_ANSWERS_API_KEY

CONTEXT7_API_KEY=
context7-docs.api_key=

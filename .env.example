# Copy to .env and fill secrets. Never commit .env.

# --- Listen (cloud-safe default: loopback only) ---
MCP_SEARCH_BIND=127.0.0.1
MCP_SEARCH_PORT=8812

# --- Servers enabled on the gateway (comma-separated catalog names) ---
# Core (no paid keys):
MCP_SEARCH_SERVERS=searxng-mcp-local
# Full example (uncomment / replace when keys are set):
# MCP_SEARCH_SERVERS=searxng-mcp-local,tavily,firecrawl,brave,context7-docs,deepwiki,arxiv-mcp-server

# --- Images ---
SEARXNG_MCP_IMAGE=xbeta/mcp-search-searxng:latest
SEARXNG_SECRET=change-me-to-a-long-random-string

# --- Optional paid / remote backends (only needed if listed in MCP_SEARCH_SERVERS) ---
TAVILY_API_KEY=
# Docker MCP catalog secret alias (gateway also accepts dotted form):
tavily.api_key=

FIRECRAWL_API_KEY=
firecrawl.api_key=

BRAVE_API_KEY=
brave.api_key=

CONTEXT7_API_KEY=
context7-docs.api_key=

# Brave Answers (future — separate key; not wired until catalog entry exists)
# BRAVE_ANSWERS_API_KEY=
